{
  "mode": "yolo",
  "granularity": "fine",
  "model_profile": "quality",
  "commit_docs": true,
  "parallelization": false,
  "branching_strategy": "milestone",
  "quick_branch_template": null,
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "nyquist_validation": true,
    "pattern_mapper": true,
    "ui_phase": true,
    "ui_safety_gate": true,
    "ai_integration_phase": true,
    "tdd_mode": false,
    "code_review": true,
    "code_review_depth": "deep",
    "ui_review": true,
    "skip_discuss": false,
    "use_worktrees": true,
    "research_before_questions": true,
    "discuss_mode": "assumptions"
  },
  "intel": {
    "enabled": true
  },
  "graphify": {
    "enabled": true
  },
  "hooks": {
    "context_warnings": true
  },
  "resolve_model_ids": "omit"
}
